{
  "name": "accshift",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "check": "vp check && vp run check:frontend && vp run check:rust",
    "check:frontend": "svelte-check --tsconfig ./tsconfig.json",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "fmt:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --check",
    "clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "preview": "vp preview",
    "tauri": "tauri",
    "prepare": "vp config"
  },
  "dependencies": {
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-process": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.10.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@tsconfig/svelte": "^5.0.8",
    "svelte": "^5.54.1",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.6.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.13",
    "vite-plus": "0.1.13",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.13"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@0.1.13",
      "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.13"
    }
  }
}
