{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Accshift",
  "version": "1.0.0",
  "identifier": "com.accshift.desktop",
  "mainBinaryName": "accshift-gui",
  "build": {
    "beforeDevCommand": "cargo build -p accshift-cli --release && node scripts/stage-cli.mjs && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cargo build -p accshift-cli --release && node scripts/stage-cli.mjs && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https://*.steamstatic.com https://steamcdn-a.akamaihd.net https://*.rbxcdn.com; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "deb", "rpm", "appimage", "app", "dmg"],
    "externalBin": ["binaries/accshift"],
    "category": "Utility",
    "shortDescription": "Multi-platform desktop account switcher",
    "longDescription": "Accshift is a fast desktop account switcher for Steam, Riot, Battle.net, Epic, Ubisoft and Roblox. GUI + CLI, built with Tauri 2 and Svelte 5.",
    "homepage": "https://github.com/klNuno/accshift",
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/installer/nsis-header.bmp",
        "sidebarImage": "icons/installer/nsis-sidebar.bmp",
        "installMode": "currentUser",
        "startMenuFolder": "Accshift",
        "languages": ["English", "French"],
        "displayLanguageSelector": false,
        "compression": "lzma",
        "installerHooks": "./windows/hooks.nsh"
      },
      "wix": {
        "language": "en-US",
        "bannerPath": "icons/installer/wix-banner.bmp",
        "dialogImagePath": "icons/installer/wix-dialog.bmp"
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"],
        "section": "utils"
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3"],
        "epoch": 0
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "11.0",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["accshift"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY5QjgxOUY2RjJFMjU5NTMKUldSVFdlTHk5aG00YVVla0RIQ25oZGlMc2tWRVVMTUQrSG96bUtiQ2ZLNFlSRkpmS1pGcVlKSzcK",
      "endpoints": ["https://github.com/klNuno/accshift/releases/latest/download/latest.json"],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
